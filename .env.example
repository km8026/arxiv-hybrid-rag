# ---- LLM (LiteLLM) ----
# 로컬: ollama/qwen2.5:7b-instruct   |   API: openai/gpt-4o-mini, anthropic/claude-3-5-sonnet-latest
LLM_MODEL=ollama/qwen2.5:7b-instruct
LLM_API_BASE=http://localhost:11434
# API 백엔드 사용 시에만 입력 (로컬 Ollama면 비워둠)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ---- Embeddings ----
EMBED_MODEL=ollama/bge-m3
EMBED_DIM=1024

# ---- Qdrant ----
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=papers

# ---- Neo4j ----
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password123

# ---- Semantic Scholar (인용 보강) ----
# 키 없이도 동작하나 rate limit 완화를 위해 권장
SEMANTIC_SCHOLAR_API_KEY=

# ---- Corpus 범위 ----
ARXIV_CATEGORIES=cs.CL,cs.AI
ARXIV_YEAR_MIN=2022
ARXIV_YEAR_MAX=2025
